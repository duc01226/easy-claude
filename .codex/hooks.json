{
  "PostToolUse": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ./.claude/hooks/tool-output-swap.cjs"
        }
      ],
      "matcher": "Read|Grep|Glob"
    },
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ./.claude/hooks/bash-cleanup.cjs"
        }
      ],
      "matcher": "Bash"
    },
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ./.claude/hooks/post-edit-prettier.cjs"
        }
      ],
      "matcher": "Edit|Write|MultiEdit"
    },
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ./.claude/hooks/graph-auto-update.cjs"
        }
      ],
      "matcher": "Edit|Write|MultiEdit"
    },
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ./.claude/hooks/todo-tracker.cjs"
        }
      ],
      "matcher": "TaskCreate|TaskUpdate"
    },
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ./.claude/hooks/workflow-step-tracker.cjs"
        }
      ],
      "matcher": "Skill"
    },
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ./.claude/hooks/post-agent-validator.cjs"
        }
      ],
      "matcher": "Agent"
    }
  ],
  "PreToolUse": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ./.claude/hooks/notify-waiting.js"
        }
      ],
      "matcher": "AskUserQuestion"
    },
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ./.claude/hooks/windows-command-detector.cjs"
        },
        {
          "type": "command",
          "command": "node ./.claude/hooks/git-commit-block.cjs"
        },
        {
          "type": "command",
          "command": "node ./.claude/hooks/doc-sync-gate.cjs"
        }
      ],
      "matcher": "Bash"
    },
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ./.claude/hooks/scout-block.cjs"
        },
        {
          "type": "command",
          "command": "node ./.claude/hooks/privacy-block.cjs"
        }
      ],
      "matcher": "Bash|Glob|Grep|Read|Edit|Write|NotebookEdit"
    },
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ./.claude/hooks/path-boundary-block.cjs"
        }
      ],
      "matcher": "Bash|Edit|Write|MultiEdit|NotebookEdit"
    },
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ./.claude/hooks/edit-enforcement.cjs"
        }
      ],
      "matcher": "Edit|Write|MultiEdit|NotebookEdit"
    },
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ./.claude/hooks/skill-enforcement.cjs"
        },
        {
          "type": "command",
          "command": "node ./.claude/hooks/agent-files-skill-gate.cjs"
        }
      ],
      "matcher": "Skill"
    },
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ./.claude/hooks/workflow-task-guard.cjs"
        }
      ],
      "matcher": "TaskUpdate"
    },
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ./.claude/hooks/doc-sync-gate.cjs"
        }
      ],
      "matcher": "Write|Edit|MultiEdit"
    },
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ./.claude/hooks/path-boundary-block.cjs"
        }
      ],
      "matcher": "mcp__filesystem__*"
    }
  ],
  "SessionStart": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ./.claude/hooks/verify-install.cjs"
        }
      ],
      "matcher": "startup|resume"
    },
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ./.claude/hooks/session-init.cjs"
        }
      ],
      "matcher": "startup|resume"
    },
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ./.claude/hooks/post-compact-recovery.cjs"
        }
      ],
      "matcher": "startup|resume"
    },
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ./.claude/hooks/session-resume.cjs"
        }
      ],
      "matcher": "startup|resume"
    },
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ./.claude/hooks/session-init-docs.cjs"
        }
      ],
      "matcher": "startup|resume"
    },
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ./.claude/hooks/graph-session-init.cjs"
        }
      ],
      "matcher": "startup|resume"
    },
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ./.claude/hooks/workflow-router.cjs"
        }
      ],
      "matcher": "startup|resume"
    }
  ],
  "Stop": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ./.claude/hooks/notify-waiting.js"
        }
      ]
    }
  ],
  "UserPromptSubmit": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ./.claude/hooks/init-prompt-gate.cjs"
        }
      ]
    },
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ./.claude/hooks/pre-compact-snapshot.cjs"
        }
      ]
    }
  ]
}
