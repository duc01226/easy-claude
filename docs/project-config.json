      ]
    },
    {
      "filename": "domain-entities-reference.md",
      "purpose": "Framework conceptual domain — Hook, Skill, Agent, Workflow, Context Group, Module",
      "sections": ["hook", "skill", "agent", "workflow", "context-group", "module", "entity-relationships"]
    },
    {
      "filename": "docs-index-reference.md",
